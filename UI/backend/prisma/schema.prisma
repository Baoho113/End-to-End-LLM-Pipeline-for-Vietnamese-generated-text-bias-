// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User Model - stores authenticated users
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String   // hashed with bcrypt
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  conversations Conversation[]
  chats         Chat[]

  @@index([email])
}

// Conversation Model - represents a session/analysis session
model Conversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("Untitled")
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  chats     Chat[]

  @@index([userId])
}

// Chat Model - individual messages with bias analysis
model Chat {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Message content
  role           String   // "user" or "assistant"
  text           String   // message text

  // Bias analysis data (JSON)
  biasData       String?  // stores JSON as string: { summary, overall, biases: [...] }

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([conversationId])
  @@index([userId])
}
